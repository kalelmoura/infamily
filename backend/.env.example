# Backend environment variables — copy this file to `.env` and fill in values.
# The real `.env` is gitignored; never commit secrets.

# --- Phase 0 (active) ---
# Allowed CORS origin: the frontend's URL. Local Next.js dev default below.
FRONTEND_ORIGIN=http://localhost:3000

# --- Added in later phases (leave commented until then) ---
# Phase 1+ — Postgres connection string (backend-only; never in the frontend).
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/postgres
#
# Phase 1 — Supabase JWKS endpoint, used to verify access tokens.
# SUPABASE_JWKS_URL=https://YOUR-PROJECT.supabase.co/auth/v1/.well-known/jwks.json
#
# Optional, only if the backend ever calls the Supabase API directly (server-side only):
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_SECRET_KEY=sb_secret_...
